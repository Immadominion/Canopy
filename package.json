{
    "name": "canopy",
    "version": "0.0.0",
    "private": true,
    "packageManager": "pnpm@10.33.1",
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=10.33.1"
    },
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "typecheck": "turbo typecheck",
        "test": "turbo test",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .prettierignore",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\" --ignore-path .prettierignore",
        "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@typescript-eslint/eslint-plugin": "^8.32.1",
        "@typescript-eslint/parser": "^8.32.1",
        "eslint": "^9.27.0",
        "prettier": "^3.5.3",
        "turbo": "^2.9.14",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.1"
    },
    "pnpm": {
        "overrides": {
            "react-native": "0.76.7",
            "@react-native/virtualized-lists>@types/react": "~18.3.0"
        },
        "packageExtensions": {
            "expo-router": {
                "peerDependencies": {
                    "@types/react": "~18.3.0"
                }
            }
        }
    }
}