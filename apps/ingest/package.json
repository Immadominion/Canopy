{
  "name": "@canopy/ingest",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "wrangler dev --env local",
    "deploy": "wrangler deploy --env production",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format:check": "prettier --check \"src/**/*.{ts}\" --ignore-path ../../.prettierignore"
  },
  "dependencies": {
    "@canopy/types": "workspace:*",
    "hono": "^4.12.21",
    "pg": "^8.21.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250521.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "eslint": "^9.27.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.15.0"
  }
}
