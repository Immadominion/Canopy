# Base URL of the Canopy web API. On a physical device, localhost points at the
# device — use your Mac's LAN IP (e.g. http://192.168.1.20:3000) or a tunnel.
EXPO_PUBLIC_CANOPY_API_URL=http://localhost:3000

# Optional — analytics for the tester app itself.
EXPO_PUBLIC_CANOPY_API_KEY=
EXPO_PUBLIC_CANOPY_APP_ID=
EXPO_PUBLIC_CANOPY_INGEST_URL=
