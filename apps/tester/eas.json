                "EXPO_PUBLIC_CANOPY_INGEST_URL": "https://ingest.trycanopy.xyz",
                "EXPO_PUBLIC_CANOPY_APP_ID": "735a773e-213d-4a98-ae83-e574ab9b7312"
            }
        },
        "production": {
            "autoIncrement": true,
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_PUBLIC_CANOPY_API_URL": "https://www.trycanopy.xyz",
                "EXPO_PUBLIC_CANOPY_INGEST_URL": "https://ingest.trycanopy.xyz",
                "EXPO_PUBLIC_CANOPY_APP_ID": "735a773e-213d-4a98-ae83-e574ab9b7312"
            }
