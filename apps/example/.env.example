# Canopy SDK — environment variables for apps/example
# Copy this file to .env.local and fill in your values.
# EXPO_PUBLIC_ variables are embedded at build time and visible to the app bundle.
# Never put secrets in EXPO_PUBLIC_ variables.

# Required — from the Canopy dashboard (Settings → API Keys)
EXPO_PUBLIC_CANOPY_API_KEY=cny_your_api_key_here
EXPO_PUBLIC_CANOPY_APP_ID=app_your_app_id_here

# Optional — override the ingest endpoint for local development
# EXPO_PUBLIC_CANOPY_INGEST_URL=http://10.0.2.2:8787
