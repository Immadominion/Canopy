{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2022"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "preserve",
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@canopy/types": [
                "../../packages/types/src/index.ts"
            ],
            "@canopy/utils": [
                "../../packages/utils/src/index.ts"
            ]
        },
        "plugins": [
            {
                "name": "next"
            }
        ],
        "incremental": true
    },
    "include": [
        "next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}