JWT_SECRET=
SIWS_NONCE_TTL_SECONDS=300

# ─── Arweave / Irys ───
IRYS_PRIVATE_KEY=
IRYS_NETWORK=mainnet

# ─── Ingest Service ───
INGEST_BASE_URL=https://ingest.canopy.dev

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
