{
    "name": "@canopy/docs",
    "version": "0.0.0",
    "private": true,
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "dev": "next dev --turbopack --port 3001",
        "build": "next build",
        "start": "next start",
        "lint": "eslint src --max-warnings 0",
        "typecheck": "fumadocs-mdx && tsc --noEmit",
        "format:check": "prettier --check \"**/*.{ts,tsx,css,mdx}\" --ignore-path ../../.prettierignore"
    },
    "dependencies": {
        "@scalar/nextjs-api-reference": "^0.10.14",
        "@types/mdx": "^2.0.13",
        "fumadocs-core": "^16.9.1",
        "fumadocs-mdx": "^15.0.8",
        "fumadocs-openapi": "^10.8.6",
        "fumadocs-ui": "^16.9.1",
        "next": "^16.2.6",
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "eslint": "^9.27.0",
        "eslint-config-next": "^16.2.6",
        "postcss": "^8.5.3",
        "tailwindcss": "^4.1.6",
        "typescript": "^5.8.3"
    }
}