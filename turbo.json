{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                ".env*"
            ],
            "env": [
                "NODE_ENV",
                "NEXT_PUBLIC_SUPABASE_URL",
                "NEXT_PUBLIC_SUPABASE_ANON_KEY",
                "SUPABASE_SERVICE_ROLE_KEY",
                "SOLANA_RPC_URL",
                "HELIUS_API_KEY",
                "R2_ACCOUNT_ID",
                "R2_ACCESS_KEY_ID",
                "R2_SECRET_ACCESS_KEY",
                "R2_BUCKET_NAME",
                "R2_PUBLIC_URL",
                "R2_SIGNING_SECRET",
                "JWT_SECRET",
                "SIWS_NONCE_TTL_SECONDS",
                "IRYS_PRIVATE_KEY",
                "IRYS_NETWORK",
                "VIRUSTOTAL_API_KEY",
                "NEXT_PUBLIC_APP_URL",
                "INGEST_BASE_URL",
                "CRON_SECRET",
                "HEALTH_TOKEN",
                "RESEND_API_KEY",
                "RESEND_FROM_EMAIL",
                "TELEGRAM_BOT_TOKEN",
                "TELEGRAM_ADMIN_CHAT_ID",
                "TELEGRAM_WEBHOOK_SECRET",
                "ADMIN_WALLET_HASHES",
                "NEXT_PUBLIC_FOUNDER_TELEGRAM",
                "CANOPY_MERCHANT_WALLET",
                "USDC_MINT",
                "SOLANA_CLUSTER",
                "HERALD_API_KEY",
                "HERALD_BASE_URL"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "dist/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$",
                "tsconfig*.json"
            ]
        },
        "test": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "$TURBO_DEFAULT$"
            ]
        },
        "format:check": {
            "inputs": [
                "$TURBO_DEFAULT$"
            ]
        },
        "clean": {
            "cache": false
        }
    }
}