{
    "name": "@canopy/types",
    "version": "0.0.0",
    "private": true,
    "engines": {
        "node": ">=24.0.0"
    },
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts"
        }
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --max-warnings 0",
        "format:check": "prettier --check \"src/**/*.{ts}\" --ignore-path ../../.prettierignore"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.32.1",
        "@typescript-eslint/parser": "^8.32.1",
        "eslint": "^9.27.0",
        "typescript": "^5.8.3"
    }
}