# Canopy — Developer Infrastructure for Solana Mobile

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
.next/
dist/
build/
out/
.turbo/

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Keep example env files
!.env.example

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
*.lcov

# Misc
.DS_Store
*.pem
.idea/
.vscode/settings.json
*.swp
*.swo

# Cloudflare Workers
.wrangler/
*.wasm

# APK files (never commit these)
*.apk
*.aab

# Supabase local dev
supabase/.branches/
supabase/.temp/

# Generated docs assets (fumadocs-mdx)
apps/docs/.source/

# TypeScript / Next build artifacts
*.tsbuildinfo
next-env.d.ts

# Expo / React Native generated native projects (regenerated via `expo prebuild`)
.expo/
apps/tester/android/
apps/tester/ios/
apps/example/android/
apps/example/ios/

# Design source masters (optimized copies live in apps/web/public)
design-assets/

# Self-hosted Rive runtime — needed at /rive.wasm, exempt from the *.wasm rule above
!apps/web/public/rive.wasm
